// COMBINED ALERT SYSTEM — Chosen One + Dip Buyer
// ================================================
// SETUP:
// 1. Load this indicator on the ES1! daily chart in TradingView
// 2. Create ONE alert on this indicator:
//    - Condition: "Combined Alert System" — "Any alert() function call"
//    - Trigger: "Once Per Bar Close"
//    - Expiration: set to max (or "Open-ended" on paid plans)
//    - Webhook URL: https://your-worker.workers.dev (your Cloudflare relay)
// 3. The system sends ONE message per day to Telegram via the webhook
// 4. Action messages (🟢🔴🔵✅) tell you exactly what to do
// 5. Heartbeat messages (💤) confirm the system is alive
// 6. Warning messages (⚠️) mean something needs manual attention
// 7. If you stop receiving daily messages, the alert has expired or broken
//
// STRATEGIES:
// - Chosen One: Week 1 & 4 calendar hold (Mon open -> Fri close)
// - Dip Buyer: RSI mean reversion (1-5 day holds during pullbacks)
// - Only one position at a time — system manages overlap automatically
//
// KNOWN LIMITATIONS:
// - Dip Buyer RSI exit fires at bar close — ~1 day delay vs backtest
// - VIX data from CBOE:VIX may have slight delay vs real-time
// - Lookahead buffer uses calendar math (approximate +/-1 day)

//@version=5
indicator("Combined Alert System — Chosen One + Dip Buyer", "CO+DB Alerts", overlay=false, max_bars_back=500)

// ============================================================================
// CONSTANTS
// ============================================================================
string TZ       = "America/New_York"
float VIX_DZ_LO = 15.0    // Chosen One VIX dead zone lower bound (inclusive)
float VIX_DZ_HI = 20.0    // Chosen One VIX dead zone upper bound (inclusive)
int   RSI_LEN   = 2       // Dip Buyer RSI period
float RSI_IN    = 10.0    // Dip Buyer RSI entry threshold (below)
float RSI_OUT   = 65.0    // Dip Buyer RSI exit threshold (above)
int   DB_MAX    = 5       // Dip Buyer max hold days (time stop)
float DB_VIX_LO = 20.0    // Dip Buyer VIX floor (above, strict)
float DB_VIX_HI = 35.0    // Dip Buyer VIX ceiling (below, strict)
int   BUFFER    = 5        // Lookahead buffer weekdays before CO week

// ============================================================================
// DATA
// ============================================================================
vixClose = request.security("CBOE:VIX", "D", close, barmerge.gaps_off, barmerge.lookahead_off)
rsi2     = ta.rsi(close, RSI_LEN)
bool vixOk = not na(vixClose)

// ============================================================================
// TIME CALCULATIONS
// ============================================================================
int dow = dayofweek(time, TZ)
bool isMonday  = dow == dayofweek.monday
bool isFriday  = dow == dayofweek.friday

// Week of month — always based on the Monday of the current trading week.
// Edge case: if the 1st of a month falls mid-week, that week's Monday is in
// the prior month. The week number reflects the Monday's day-of-month, so
// that week is NOT Week 1 of the new month. Week 1 starts with the first
// Monday whose day-of-month is 1-7.
int daysFromMon = dow - dayofweek.monday  // Mon=0, Tue=1, ..., Fri=4
int mondayMs    = time - daysFromMon * 86400000
int mondayDom   = dayofmonth(mondayMs, TZ)
int weekOfMonth = int(math.floor((mondayDom - 1) / 7.0)) + 1
bool isCoWeek   = weekOfMonth == 1 or weekOfMonth == 4

string dayName = isMonday ? "Mon" :
     dow == dayofweek.tuesday ? "Tue" :
     dow == dayofweek.wednesday ? "Wed" :
     dow == dayofweek.thursday ? "Thu" :
     isFriday ? "Fri" : "?"

// Next Monday calculation — used for Friday heads-up
// Do NOT compute "next week" from current week number; instead compute
// the actual calendar date of next Monday and derive its week_of_month.
int daysToNextMon = isFriday ? 3 :
     dow == dayofweek.thursday ? 4 :
     dow == dayofweek.wednesday ? 5 :
     dow == dayofweek.tuesday ? 6 :
     isMonday ? 7 : 0
int nextMonMs    = time + daysToNextMon * 86400000
int nextMonDom   = dayofmonth(nextMonMs, TZ)
int nextMonWom   = int(math.floor((nextMonDom - 1) / 7.0)) + 1
bool nextMonIsCo = nextMonWom == 1 or nextMonWom == 4

// ============================================================================
// LOOKAHEAD BUFFER — find next CO Monday within 42 calendar days
// Count weekdays (Mon-Fri) between today and that Monday.
// If fewer than BUFFER (5) weekdays, Dip Buyer entry is blocked.
// ============================================================================
int coMonDist = 0
for i = 1 to 42
    int ft  = time + i * 86400000
    int fdw = dayofweek(ft, TZ)
    if fdw == dayofweek.monday
        int fd  = dayofmonth(ft, TZ)
        int fw  = int(math.floor((fd - 1) / 7.0)) + 1
        if fw == 1 or fw == 4
            coMonDist := i
            break

int wdToNextCo = 0
if coMonDist > 0
    for i = 1 to coMonDist
        int ft  = time + i * 86400000
        int fdw = dayofweek(ft, TZ)
        if fdw >= dayofweek.monday and fdw <= dayofweek.friday
            wdToNextCo += 1

bool bufferBlocked = coMonDist > 0 and wdToNextCo < BUFFER

// ============================================================================
// STATE VARIABLES (persist across bars)
// ============================================================================
var bool  coActive       = false
var int   coDayCount     = 0
var bool  coWeekSkipped  = false
var bool  dbActive       = false
var int   dbDayCount     = 0
var bool  dbPending      = false

// ============================================================================
// CORE LOGIC — runs only on confirmed (closed) bars to prevent repainting.
// On historical bars barstate.isconfirmed is always true.
// On the real-time bar it becomes true once at the close.
// ============================================================================
if barstate.isconfirmed
    // ------------------------------------------------------------------
    // Per-bar action flags (local to this block)
    // ------------------------------------------------------------------
    bool coEntry     = false
    bool coExit      = false
    bool coSkip      = false
    bool coHeadsUp   = false
    bool coHuBuy     = false
    bool coHuSkip    = false
    bool dbSignal    = false
    bool dbRsiExit   = false
    bool dbTimeStop  = false

    // ------------------------------------------------------------------
    // CHOSEN ONE — entry / hold / exit
    // ------------------------------------------------------------------
    // On Monday, check Friday's VIX (prior bar on daily chart = Friday)
    float fridayVix     = isMonday ? nz(vixClose[1], 0.0) : nz(vixClose, 0.0)
    bool  vixInDeadZone = fridayVix >= VIX_DZ_LO and fridayVix <= VIX_DZ_HI

    if isMonday and isCoWeek and not coActive
        bool haveVix = isMonday ? not na(vixClose[1]) : vixOk
        if haveVix
            if not vixInDeadZone
                coActive      := true
                coDayCount    := 1
                coEntry       := true
                coWeekSkipped := false
            else
                coSkip        := true
                coWeekSkipped := true
        else
            coSkip        := true
            coWeekSkipped := true
    else if isMonday and not isCoWeek
        coWeekSkipped := false

    // Increment day count (Tue-Fri while active)
    if coActive and not coEntry
        coDayCount += 1

    // Save count for exit message before potential reset
    int coExitDay = coDayCount

    // Friday exit
    if isFriday and coActive
        coExit     := true
        coActive   := false
        coDayCount := 0

    // Safety: Chosen One has priority — force-close Dip Buyer if both active
    if coActive and dbActive
        dbActive   := false
        dbDayCount := 0

    // Friday heads-up for NEXT Monday
    if isFriday and nextMonIsCo
        coHeadsUp := true
        if vixOk
            bool dzNow = vixClose >= VIX_DZ_LO and vixClose <= VIX_DZ_HI
            coHuBuy  := not dzNow
            coHuSkip := dzNow
        else
            coHuSkip := true

    // ------------------------------------------------------------------
    // DIP BUYER — pending entry execution
    // ------------------------------------------------------------------
    if dbPending
        if not coActive and not isCoWeek
            dbActive   := true
            dbDayCount := 0   // will be incremented below
            dbPending  := false
        else
            dbPending := false   // CO week started or CO active, cancel

    // Increment hold days for active position
    if dbActive
        dbDayCount += 1

    // Save count for exit message
    int dbExitDay = dbDayCount

    // Check exit conditions
    if dbActive
        if not na(rsi2) and rsi2 > RSI_OUT
            dbRsiExit  := true
            dbActive   := false
            dbDayCount := 0
        else if dbDayCount >= DB_MAX
            dbTimeStop := true
            dbActive   := false
            dbDayCount := 0

    // Check for new entry signal (entry will be NEXT bar's open)
    if not dbActive and not dbPending and not coActive
        if isCoWeek
            noop = 0  // blocked by CO week
        else if bufferBlocked
            noop = 0  // blocked by lookahead buffer
        else if not vixOk
            noop = 0  // no VIX data
        else if vixClose <= DB_VIX_LO or vixClose >= DB_VIX_HI
            noop = 0  // VIX out of range
        else if not na(rsi2) and rsi2 < RSI_IN
            // Signal fires — entry will be next trading day's open
            if isFriday
                // Entry would be Monday. Check if that Monday is a CO week.
                if not nextMonIsCo
                    dbPending := true
                    dbSignal  := true
                // else: suppress — Monday starts a Chosen One week
            else
                dbPending := true
                dbSignal  := true

    // ------------------------------------------------------------------
    // STATUS STRINGS (for message construction)
    // ------------------------------------------------------------------
    string rsiStr = na(rsi2) ? "N/A" : str.tostring(rsi2, "#.##")
    string vixStr = na(vixClose) ? "N/A" : str.tostring(vixClose, "#.##")

    string coStatus = coActive   ? "ACTIVE Day " + str.tostring(coDayCount) + "/5" :
         coExit                  ? "CLOSED (Friday)" :
         (isCoWeek and coWeekSkipped) ? "SKIP (VIX 15-20)" :
         "INACTIVE (Week " + str.tostring(weekOfMonth) + ")"

    string dbStatus = dbActive   ? "ACTIVE Day " + str.tostring(dbDayCount) + "/5" :
         dbPending               ? "ENTRY PENDING (tomorrow)" :
         isCoWeek                ? "BLOCKED (CO week)" :
         bufferBlocked           ? "BLOCKED (buffer <5d)" :
         (vixOk and (vixClose <= DB_VIX_LO or vixClose >= DB_VIX_HI)) ? "INACTIVE (VIX out of range)" :
         "HUNTING"

    // ------------------------------------------------------------------
    // MESSAGE CONSTRUCTION — build incrementally, multiple actions combine
    // ------------------------------------------------------------------
    string msg = ""
    string sep = ""

    if not vixOk
        // VIX warning overrides everything
        msg := "⚠️ SYSTEM WARNING\nVIX data unavailable — check manually before trading\nRSI(2): " + rsiStr + " | Week: " + str.tostring(weekOfMonth)

    else
        // Chosen One Friday exit
        if coExit
            msg += sep + "🔴 CHOSEN ONE — CLOSE POSITION\nWeek " + str.tostring(weekOfMonth) + " | Friday close\nSell 1 ES before 4:00 PM today\n---\nRSI(2): " + rsiStr + " | VIX: " + vixStr
            sep := "\n\n"

        // Chosen One Friday heads-up
        if coHeadsUp and coHuBuy
            msg += sep + "🟢 CHOSEN ONE — TRADE MONDAY\nWeek " + str.tostring(nextMonWom) + " | VIX: " + vixStr + "\nBuy 1 ES at 9:30 AM open Monday\n---\nRSI(2): " + rsiStr + " | Dip Buyer: " + dbStatus
            sep := "\n\n"
        if coHeadsUp and coHuSkip
            msg += sep + "🔴 CHOSEN ONE — SKIP MONDAY\nWeek " + str.tostring(nextMonWom) + " | VIX: " + vixStr + " (in 15-20 dead zone)\nNo trade this week\n---\nRSI(2): " + rsiStr + " | Dip Buyer: " + dbStatus
            sep := "\n\n"

        // Chosen One Monday confirmation
        if coEntry
            msg += sep + "✅ CHOSEN ONE — POSITION OPEN\nWeek " + str.tostring(weekOfMonth) + " | Entry at Monday open\nHold until Friday close\n---\nRSI(2): " + rsiStr + " | VIX: " + vixStr
            sep := "\n\n"

        // Dip Buyer time stop
        if dbTimeStop
            msg += sep + "🔵 DIP BUYER — CLOSE POSITION (TIME STOP)\nRSI(2): " + rsiStr + " | Day " + str.tostring(dbExitDay) + " of 5\nSell 1 ES before 4:00 PM today\n---\nChosen One: " + coStatus
            sep := "\n\n"

        // Dip Buyer RSI exit
        if dbRsiExit
            msg += sep + "🔵 DIP BUYER — CLOSE POSITION\nRSI(2): " + rsiStr + " crossed above 65 at today's close\nSell position in after-hours or at tomorrow's open\nDay " + str.tostring(dbExitDay) + " of 5\n---\nChosen One: " + coStatus
            sep := "\n\n"

        // Dip Buyer entry signal
        if dbSignal
            string buyWhen = isFriday ? "Buy 1 ES at Monday 9:30 AM open" : "Buy 1 ES at 9:30 AM open tomorrow"
            msg += sep + "🔵 DIP BUYER — BUY TOMORROW\nRSI(2): " + rsiStr + " | VIX: " + vixStr + "\n" + buyWhen + "\n---\nChosen One: " + coStatus
            sep := "\n\n"

        // Heartbeat (no action today)
        if msg == ""
            string nextAct = coActive and isFriday                     ? "CO exit at Friday close today" :
                 coActive                                              ? "CO holding, exit Friday close" :
                 dbActive and dbDayCount == DB_MAX - 1                 ? "DB Day 4/5 — time stop tomorrow if RSI < 65" :
                 dbActive                                              ? "DB holding, exit RSI > 65 or day " + str.tostring(DB_MAX) :
                 (isFriday and nextMonIsCo)                            ? "CO decision this Friday" :
                 "Monitoring for signals"
            msg := "💤 DAILY STATUS\nWeek " + str.tostring(weekOfMonth) + " | Day: " + dayName +
                 "\nVIX: " + vixStr + " | RSI(2): " + rsiStr +
                 "\nChosen One: " + coStatus +
                 "\nDip Buyer: " + dbStatus +
                 "\nNext action: " + nextAct

    // ------------------------------------------------------------------
    // FIRE ALERT — single alert per bar close with dynamic message
    // ------------------------------------------------------------------
    alert(msg, alert.freq_once_per_bar_close)

// ============================================================================
// CHART VISUALS
// ============================================================================

// --- Background highlights on main chart ---
color bgMain = coActive                                      ? color.new(color.green, 85) :
     dbActive                                                ? color.new(color.blue, 85) :
     (not coActive and not dbActive and (isCoWeek or bufferBlocked)) ? color.new(color.yellow, 90) :
     na
bgcolor(bgMain, title="Strategy Background", force_overlay=true)

// --- RSI plot in indicator pane ---
color rsiCol = na(rsi2) ? color.gray :
     rsi2 < RSI_IN  ? color.green :
     rsi2 > RSI_OUT ? color.red   :
     color.white
plot(rsi2, "RSI(2)", rsiCol, linewidth=2)

// --- VIX plot in indicator pane ---
plot(vixClose, "VIX", color.orange, linewidth=1)

// --- Reference lines ---
h10 = hline(RSI_IN,   "RSI Entry (10)", color.green,  hline.style_solid)
h65 = hline(RSI_OUT,  "RSI Exit (65)",  color.red,    hline.style_solid)
h15 = hline(VIX_DZ_LO, "VIX 15",       color.new(color.red, 60),    hline.style_dotted)
h20 = hline(VIX_DZ_HI, "VIX 20",       color.new(color.orange, 60), hline.style_dotted)
h35 = hline(DB_VIX_HI,  "VIX 35",      color.new(color.blue, 60),   hline.style_dotted)

// --- VIX zone shading ---
fill(h15, h20, color=color.new(color.red,  92), title="VIX Dead Zone 15-20")
fill(h20, h35, color=color.new(color.blue, 92), title="VIX Dip Buyer Zone 20-35")

// ============================================================================
// INFO TABLE — top-right of main chart
// ============================================================================
// Display-safe status strings (computed outside isconfirmed for table updates)
string coDispStatus = coActive ? "ACTIVE Day " + str.tostring(coDayCount) + "/5" :
     (isCoWeek and coWeekSkipped)  ? "SKIP (VIX 15-20)" :
     isCoWeek                      ? "CO WEEK" :
     "INACTIVE (W" + str.tostring(weekOfMonth) + ")"

string dbDispStatus = dbActive ? "ACTIVE Day " + str.tostring(dbDayCount) + "/5" :
     dbPending                     ? "ENTRY PENDING" :
     isCoWeek                      ? "BLOCKED (CO week)" :
     bufferBlocked                 ? "BLOCKED (buffer <5d)" :
     (vixOk and (vixClose <= DB_VIX_LO or vixClose >= DB_VIX_HI)) ? "INACTIVE (VIX)" :
     "HUNTING"

string rsiDisp = na(rsi2) ? "N/A" : str.tostring(rsi2, "#.##")
string vixDisp = na(vixClose) ? "N/A" : str.tostring(vixClose, "#.##")

color rsiTblCol = na(rsi2) ? color.gray :
     rsi2 < RSI_IN  ? color.green :
     rsi2 > RSI_OUT ? color.red   :
     color.white
color vixTblCol = na(vixClose) ? color.gray :
     (vixClose >= VIX_DZ_LO and vixClose <= VIX_DZ_HI) ? color.red :
     (vixClose > DB_VIX_LO and vixClose < DB_VIX_HI)   ? color.green :
     color.white

string nextActDisp = coActive              ? "CO exit Fri close" :
     dbActive                              ? "DB exit RSI>65 / day " + str.tostring(DB_MAX) :
     "Monitoring"

var table infoTbl = table.new(position.top_right, 2, 8,
     bgcolor=color.new(color.black, 20), border_color=color.gray,
     border_width=1, frame_color=color.gray, frame_width=1,
     force_overlay=true)

if barstate.islast
    // Header
    table.cell(infoTbl, 0, 0, "CO+DB System", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(infoTbl, 1, 0, "",              text_color=color.white, text_size=size.small)
    // Week / Day
    table.cell(infoTbl, 0, 1, "Week / Day",   text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(infoTbl, 1, 1, "W" + str.tostring(weekOfMonth) + " " + dayName, text_color=color.white, text_size=size.small, text_halign=text.align_right)
    // Chosen One
    table.cell(infoTbl, 0, 2, "Chosen One",   text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(infoTbl, 1, 2, coDispStatus,    text_color=coActive ? color.green : color.white, text_size=size.small, text_halign=text.align_right)
    // Dip Buyer
    table.cell(infoTbl, 0, 3, "Dip Buyer",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(infoTbl, 1, 3, dbDispStatus,    text_color=dbActive ? color.blue : color.white, text_size=size.small, text_halign=text.align_right)
    // RSI
    table.cell(infoTbl, 0, 4, "RSI(2)",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(infoTbl, 1, 4, rsiDisp,         text_color=rsiTblCol,   text_size=size.small, text_halign=text.align_right)
    // VIX
    table.cell(infoTbl, 0, 5, "VIX",          text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(infoTbl, 1, 5, vixDisp,         text_color=vixTblCol,   text_size=size.small, text_halign=text.align_right)
    // Days to next CO
    table.cell(infoTbl, 0, 6, "Days to CO",   text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(infoTbl, 1, 6, coMonDist > 0 ? str.tostring(wdToNextCo) + " trading" : "N/A", text_color=color.white, text_size=size.small, text_halign=text.align_right)
    // Next action
    table.cell(infoTbl, 0, 7, "Next Action",  text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(infoTbl, 1, 7, nextActDisp,     text_color=color.yellow, text_size=size.small, text_halign=text.align_right)
